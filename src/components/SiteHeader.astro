---
import { siteConfig } from "../config/site";

const pathname = Astro.url.pathname;

const iconMap = {
  home: {
    viewBox: "0 0 24 24",
    paths: ["M3.75 10.25L12 3.75L20.25 10.25", "M5.25 9.75V20.25H18.75V9.75"],
  },
  blog: {
    viewBox: "0 0 24 24",
    paths: ["M6 4.5H18A1.5 1.5 0 0 1 19.5 6V18A1.5 1.5 0 0 1 18 19.5H6A1.5 1.5 0 0 1 4.5 18V6A1.5 1.5 0 0 1 6 4.5Z", "M8.25 9H15.75", "M8.25 12H15.75", "M8.25 15H12.75"],
  },
  tag: {
    viewBox: "0 0 24 24",
    paths: ["M10.5 4.5H18.75V12.75L11.25 20.25L3.75 12.75L10.5 4.5Z", "M14.625 8.625H14.633"],
  },
  archive: {
    viewBox: "0 0 24 24",
    paths: ["M4.5 7.5H19.5V18A1.5 1.5 0 0 1 18 19.5H6A1.5 1.5 0 0 1 4.5 18V7.5Z", "M3.75 4.5H20.25V7.5H3.75V4.5Z", "M10.5 10.5H13.5"],
  },
  mail: {
    viewBox: "0 0 24 24",
    paths: ["M4.5 6.75H19.5V17.25H4.5V6.75Z", "M5.25 7.5L12 12.75L18.75 7.5"],
  },
  history: {
    viewBox: "0 0 24 24",
    paths: ["M4.5 12A7.5 7.5 0 1 0 6.697 6.697", "M4.5 4.5V9H9", "M12 8.25V12L14.625 13.5"],
  },
} as const;
---

<header class="site-header">
  <div class="container shell-card shell-card--dense header-inner">
    <a class="brand-block" href="/">
      <span class="brand-mark">
        <img src={siteConfig.avatarPath} alt="HansBug 的 GitHub 头像" />
      </span>
      <span>
        <strong>{siteConfig.shortTitle}</strong>
        <small>{siteConfig.tagline}</small>
      </span>
    </a>
    <nav class="main-nav" aria-label="主导航">
      {
        siteConfig.nav.map((item) => {
          const isExternal = "external" in item && item.external;
          const icon = iconMap[item.icon];
          const active = isExternal
            ? false
            : (
            item.href === "/"
              ? pathname === item.href
              : pathname.startsWith(item.href)
          );

          return (
            <a
              class:list={["nav-link", active && "is-active"]}
              href={item.href}
              target={isExternal ? "_blank" : undefined}
              rel={isExternal ? "noreferrer" : undefined}
            >
              <span class="nav-link__icon" aria-hidden="true">
                <svg viewBox={icon.viewBox}>
                  {icon.paths.map((path) => <path d={path} />)}
                </svg>
              </span>
              <span class="nav-link__label">{item.label}</span>
            </a>
          );
        })
      }
    </nav>
  </div>
</header>
