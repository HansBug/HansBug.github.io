---
interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
---

<nav class="breadcrumbs" aria-label="面包屑">
  <ol>
    {
      items.map((item) => (
        <li>
          {item.href ? <a href={item.href}>{item.label}</a> : <span>{item.label}</span>}
        </li>
      ))
    }
  </ol>
</nav>
