---
import "tom-select/dist/css/tom-select.default.css";
import type { OldBlogCatalog } from "../data/oldBlogCatalog";

interface Props {
  catalog: OldBlogCatalog;
}

const { catalog } = Astro.props;
const posts = catalog.posts;
const categories = catalog.categories;
const years = [...new Set(posts.map((post) => post.year))].sort((left, right) => right - left);
const tracks = catalog.trackCounts.map((item) => item.name);
const topCategories = categories.slice(0, 18);
const initialLimit = 24;
const defaultSortKey = "views-desc";
const initialPosts = [...posts]
  .sort((left, right) => right.views - left.views || right.dateTime.localeCompare(left.dateTime))
  .slice(0, initialLimit);
const yearlyTrendJson = JSON.stringify(catalog.yearlyTrend);
const numberFormatter = new Intl.NumberFormat("zh-CN");
---

<div class="oldblog-explorer page-grid" data-oldblog-root>
  <div class="grid-two oldblog-insights">
    <article class="oldblog-panel shell-card">
      <h3 class="oldblog-panel__title">年度趋势</h3>
      <p class="oldblog-panel__description">从年度看，旧站明显分成前期高密度积累和后期专题化写作两个阶段。</p>
      <div class="oldblog-yearchart-shell">
        <canvas class="oldblog-yearchart" data-oldblog-yearchart aria-label="旧站年度趋势图"></canvas>
      </div>
      <script type="application/json" data-oldblog-chart-data is:inline set:html={yearlyTrendJson}></script>
    </article>

    <article class="oldblog-panel shell-card">
      <h3 class="oldblog-panel__title">分类脉络</h3>
      <p class="oldblog-panel__description">这里直接用博客园旧站的真实随笔分类。点下面任一分类，会直接筛本页全量目录。</p>
      <div class="oldblog-category-cloud">
        {
          topCategories.map((item) => (
            <button type="button" class="oldblog-filter-chip" data-oldblog-shortcut={item.name}>
              <span>{item.name}</span>
              <small>{item.count}</small>
            </button>
          ))
        }
      </div>
    </article>

  </div>

  <section class="oldblog-search shell-card">
    <div class="oldblog-filter-grid">
      <label class="oldblog-field oldblog-field--wide">
        <span>检索旧文</span>
        <input
          class="search-input"
          data-oldblog-input
          type="search"
          placeholder="输入标题、分类、主题或关键词，例如：treevalue、软工、前端、算法"
        />
      </label>

      <label class="oldblog-field">
        <span>年份</span>
        <select class="oldblog-select" data-oldblog-select data-oldblog-year>
          <option value="all">全部年份</option>
          {years.map((year) => <option value={String(year)}>{year} 年</option>)}
        </select>
      </label>

      <label class="oldblog-field">
        <span>旧站分类</span>
        <select class="oldblog-select" data-oldblog-select data-oldblog-category>
          <option value="all">全部分类</option>
          {categories.map((category) => <option value={category.name}>{category.name}</option>)}
        </select>
      </label>

      <label class="oldblog-field">
        <span>归纳方向</span>
        <select class="oldblog-select" data-oldblog-select data-oldblog-track>
          <option value="all">全部归纳</option>
          {tracks.map((track) => <option value={track}>{track}</option>)}
        </select>
      </label>

      <label class="oldblog-field">
        <span>排序</span>
        <select class="oldblog-select" data-oldblog-select data-oldblog-sort>
          <option value="views-desc">按热度</option>
          <option value="comments-desc">按评论数</option>
          <option value="date-desc">按时间倒序</option>
          <option value="date-asc">按时间正序</option>
        </select>
      </label>
    </div>

    <div class="oldblog-search__meta">
      <p class="oldblog-search__count" data-oldblog-count>
        当前收录 {catalog.stats.totalPosts} 篇，累计阅读 {catalog.stats.totalViewsText}。
      </p>
      <button type="button" class="hero-action" data-oldblog-reset>重置筛选</button>
    </div>

    <div class="oldblog-results" data-oldblog-results>
      {
        initialPosts.map((post) => (
          <article class="oldblog-result">
            <div class="oldblog-result__head">
              <h3 class="oldblog-linked-title">
                <a href={post.url} target="_blank" rel="noreferrer">
                  {post.title}
                </a>
              </h3>
              <div class="oldblog-result__meta">
                <span class="tag-chip is-slate">
                  <span>发布于 {post.date}</span>
                </span>
                <span class="tag-chip is-blue">
                  <span>阅读 {numberFormatter.format(post.views)}</span>
                </span>
                <span class="tag-chip is-orange">
                  <span>评论 {post.comments}</span>
                </span>
              </div>
            </div>
            <p class="oldblog-result__summary">{post.summary || "旧站原文已保留，这里只展示索引信息与概述。"}</p>
            <div class="tag-row oldblog-result__tags">
              <span class="tag-chip is-red">
                <span>{post.track}</span>
              </span>
              {
                post.categories.length > 0 ? (
                  post.categories.map((category) => (
                    <span class="tag-chip is-slate">
                      <span>{category}</span>
                    </span>
                  ))
                ) : (
                  <span class="tag-chip is-slate">
                    <span>未挂旧站分类</span>
                  </span>
                )
              }
            </div>
          </article>
        ))
      }
    </div>

    <div class="oldblog-search__footer">
      <p class="oldblog-search__hint" data-oldblog-hint>
        标题会直接在新标签页打开博客园原文。这里默认先显示热度最高的 24 篇。
      </p>
      <button type="button" class="hero-action" data-oldblog-more>查看更多</button>
    </div>
  </section>
</div>

<script>
  import Chart from "chart.js/auto";
  import TomSelect from "tom-select";

  type EnhancedSelect = HTMLSelectElement & { tomselect?: TomSelect };

  const initOldBlogEnhancements = () => {
    const root = document.querySelector("[data-oldblog-root]");

    if (!root) return;

    root.querySelectorAll("[data-oldblog-select]").forEach((node) => {
      if (!(node instanceof HTMLSelectElement)) return;

      const selectNode = node as EnhancedSelect;
      if (selectNode.tomselect) return;

      const placeholder = selectNode.options[0]?.textContent?.trim() || "请选择";

      new TomSelect(selectNode, {
        create: false,
        maxOptions: 500,
        allowEmptyOption: true,
        hideSelected: false,
        closeAfterSelect: true,
        sortField: [{ field: "$order" }],
        placeholder,
        searchField: [],
        controlInput: null,
      });
    });

    const canvas = root.querySelector("[data-oldblog-yearchart]");
    const dataNode = root.querySelector("[data-oldblog-chart-data]");

    if (canvas instanceof HTMLCanvasElement && dataNode?.textContent) {
      const series = JSON.parse(dataNode.textContent) as Array<{ year: number; count: number }>;
      const styles = getComputedStyle(document.documentElement);
      const accent = styles.getPropertyValue("--accent").trim() || "#d65e45";
      const accentSoft = styles.getPropertyValue("--accent-soft").trim() || "rgba(214, 94, 69, 0.1)";
      const line = styles.getPropertyValue("--line").trim() || "rgba(25, 30, 35, 0.1)";
      const textMuted = styles.getPropertyValue("--text-muted").trim() || "#5c656e";

      new Chart(canvas, {
        type: "bar",
        data: {
          labels: series.map((item) => String(item.year)),
          datasets: [
            {
              data: series.map((item) => item.count),
              backgroundColor: accent,
              borderRadius: 999,
              borderSkipped: false,
              barThickness: 12,
              hoverBackgroundColor: "#171c21",
            },
          ],
        },
        options: {
          animation: false,
          indexAxis: "y",
          maintainAspectRatio: false,
          plugins: {
            legend: {
              display: false,
            },
            tooltip: {
              displayColors: false,
              backgroundColor: "rgba(17, 21, 25, 0.94)",
              bodyFont: {
                family: "IBM Plex Sans",
              },
              callbacks: {
                label(context) {
                  return `${context.raw} 篇`;
                },
              },
            },
          },
          scales: {
            x: {
              beginAtZero: true,
              border: {
                display: false,
              },
              grid: {
                color: line,
              },
              ticks: {
                color: textMuted,
                font: {
                  family: "IBM Plex Sans",
                  size: 11,
                },
                precision: 0,
              },
            },
            y: {
              border: {
                display: false,
              },
              grid: {
                display: false,
              },
              ticks: {
                color: textMuted,
                font: {
                  family: "IBM Plex Sans",
                  size: 12,
                },
              },
            },
          },
        },
        plugins: [
          {
            id: "chartAreaBackground",
            beforeDraw(chart) {
              const { ctx, chartArea } = chart;
              if (!chartArea) return;
              ctx.save();
              ctx.fillStyle = accentSoft;
              ctx.fillRect(chartArea.left, chartArea.top, chartArea.right - chartArea.left, chartArea.bottom - chartArea.top);
              ctx.restore();
            },
          },
        ],
      });
    }
  };

  initOldBlogEnhancements();
</script>

<script
  is:inline
  define:vars={{
    posts,
    initialLimit,
    defaultSortKey,
  }}
>
  const root = document.querySelector("[data-oldblog-root]");

  if (root) {
    const input = root.querySelector("[data-oldblog-input]");
    const yearSelect = root.querySelector("[data-oldblog-year]");
    const categorySelect = root.querySelector("[data-oldblog-category]");
    const trackSelect = root.querySelector("[data-oldblog-track]");
    const sortSelect = root.querySelector("[data-oldblog-sort]");
    const count = root.querySelector("[data-oldblog-count]");
    const results = root.querySelector("[data-oldblog-results]");
    const hint = root.querySelector("[data-oldblog-hint]");
    const loadMore = root.querySelector("[data-oldblog-more]");
    const reset = root.querySelector("[data-oldblog-reset]");
    const shortcutButtons = root.querySelectorAll("[data-oldblog-shortcut]");
    const setSelectValue = (select, value) => {
      if (select.tomselect) {
        select.tomselect.setValue(value, true);
        return;
      }
      select.value = value;
    };

    const numberFormatter = new Intl.NumberFormat("zh-CN");
    const state = {
      limit: initialLimit,
    };

    const escapeHtml = (value = "") =>
      value
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#39;");

    const toSearchText = (item) =>
      [item.title, item.summary, item.categories.join(" "), item.track, item.date]
        .join(" ")
        .toLowerCase();

    const rankedItems = posts.map((item) => ({
      ...item,
      searchText: toSearchText(item),
    }));

    const renderTags = (item) => {
      const tags = item.categories.length
        ? item.categories
            .map(
              (category) =>
                `<span class="tag-chip is-slate"><span>${escapeHtml(category)}</span></span>`,
            )
            .join("")
        : `<span class="tag-chip is-slate"><span>未挂旧站分类</span></span>`;

      return `<span class="tag-chip is-red"><span>${escapeHtml(item.track)}</span></span>${tags}`;
    };

    const renderItem = (item) => `
      <article class="oldblog-result">
        <div class="oldblog-result__head">
          <h3 class="oldblog-linked-title">
            <a href="${item.url}" target="_blank" rel="noreferrer">${escapeHtml(item.title)}</a>
          </h3>
          <div class="oldblog-result__meta">
            <span class="tag-chip is-slate"><span>发布于 ${escapeHtml(item.date)}</span></span>
            <span class="tag-chip is-blue"><span>阅读 ${numberFormatter.format(item.views)}</span></span>
            <span class="tag-chip is-orange"><span>评论 ${item.comments}</span></span>
          </div>
        </div>
        <p class="oldblog-result__summary">${escapeHtml(item.summary || "旧站原文已保留，这里只展示索引信息与概述。")}</p>
        <div class="tag-row oldblog-result__tags">${renderTags(item)}</div>
      </article>
    `;

    const filterItems = () => {
      const query = input.value.trim().toLowerCase();
      const year = yearSelect.value;
      const category = categorySelect.value;
      const track = trackSelect.value;

      return rankedItems
        .map((item) => {
          let score = 0;

          if (!query) {
            score = 1;
          } else {
            if (item.title.toLowerCase().includes(query)) score += 8;
            if (item.categories.join(" ").toLowerCase().includes(query)) score += 5;
            if (item.track.toLowerCase().includes(query)) score += 4;
            if (item.summary.toLowerCase().includes(query)) score += 2;
            if (item.searchText.includes(query)) score += 1;
          }

          return { item, score };
        })
        .filter(({ item, score }) => {
          if (score <= 0) return false;
          if (year !== "all" && String(item.year) !== year) return false;
          if (category !== "all" && !item.categories.includes(category)) return false;
          if (track !== "all" && item.track !== track) return false;
          return true;
        });
    };

    const sortEntries = (entries) => {
      const query = input.value.trim().toLowerCase();
      const sortKey = sortSelect.value;

      const sorters = {
        "date-desc": (left, right) => right.item.dateTime.localeCompare(left.item.dateTime),
        "date-asc": (left, right) => left.item.dateTime.localeCompare(right.item.dateTime),
        "views-desc": (left, right) => right.item.views - left.item.views || right.item.dateTime.localeCompare(left.item.dateTime),
        "comments-desc": (left, right) =>
          right.item.comments - left.item.comments || right.item.views - left.item.views || right.item.dateTime.localeCompare(left.item.dateTime),
      };

      return entries.sort((left, right) => {
        if (query && right.score !== left.score) {
          return right.score - left.score;
        }
        return sorters[sortKey](left, right);
      });
    };

    const render = () => {
      const filtered = sortEntries(filterItems());
      const visible = filtered.slice(0, state.limit).map(({ item }) => item);
      const totalViews = filtered.reduce((sum, entry) => sum + entry.item.views, 0);

      count.textContent = `当前筛出 ${filtered.length} 篇，累计阅读 ${numberFormatter.format(totalViews)}。`;
      hint.textContent =
        filtered.length > 0
          ? `已展示 ${visible.length} / ${filtered.length} 篇。标题会直接在新标签页打开博客园原文。`
          : "没有找到匹配结果，可以换更短的关键词，或者先按年份和分类缩小范围。";

      results.innerHTML = visible.length
        ? visible.map((item) => renderItem(item)).join("")
        : `
            <article class="oldblog-result oldblog-result--empty">
              <h3>没有找到匹配结果</h3>
              <p>可以试试更短的关键词，或者先切回“全部年份 / 全部分组”再继续找。</p>
            </article>
          `;

      loadMore.hidden = filtered.length <= visible.length;
    };

    const handleFilterChange = () => {
      state.limit = initialLimit;
      render();
    };

    input.addEventListener("input", handleFilterChange);
    yearSelect.addEventListener("change", handleFilterChange);
    categorySelect.addEventListener("change", handleFilterChange);
    trackSelect.addEventListener("change", handleFilterChange);
    sortSelect.addEventListener("change", handleFilterChange);

    loadMore.addEventListener("click", () => {
      state.limit += initialLimit;
      render();
    });

    reset.addEventListener("click", () => {
      input.value = "";
      setSelectValue(yearSelect, "all");
      setSelectValue(categorySelect, "all");
      setSelectValue(trackSelect, "all");
      setSelectValue(sortSelect, defaultSortKey);
      state.limit = initialLimit;
      render();
    });

    shortcutButtons.forEach((button) => {
      button.addEventListener("click", () => {
        setSelectValue(categorySelect, button.dataset.oldblogShortcut);
        state.limit = initialLimit;
        render();
      });
    });

    render();
  }
</script>
