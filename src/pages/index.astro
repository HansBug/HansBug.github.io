---
import SectionHeading from "../components/SectionHeading.astro";
import { siteConfig } from "../config/site";
import { oldBlogArchive } from "../data/oldBlogArchive";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getAllBlogPosts, getAllProjects, getAllRoutes } from "../utils/content";

const [posts, routes, projects] = await Promise.all([
  getAllBlogPosts(),
  getAllRoutes(),
  getAllProjects(),
]);
---

<BaseLayout>
  <div class="page-grid">
    <section class="hero shell-card">
      <p class="eyebrow">HansBug / 技术博客新站</p>
      <div class="hero-grid">
        <div>
          <h1>把新的技术写作、项目记录和知识索引，慢慢搭成一块长期工作台。</h1>
          <p>
            这里优先承接以后要持续更新的新内容。博客、标签、路线和项目都会先在这里生长；旧博客园内容已经转入单独的归档入口，不再占据首页主体。
          </p>
          <div class="tag-row">
            <span class="tag-chip is-red"><span>中文技术写作</span></span>
            <span class="tag-chip is-slate"><span>项目与路线并行</span></span>
            <span class="tag-chip is-blue"><span>轻工业终端感</span></span>
          </div>
          <div class="hero-actions">
            <a class="hero-action is-primary" href="/blog/">进入博客</a>
            <a class="hero-action" href="/tags/">浏览标签</a>
            <a class="hero-action" href="/contact/">联系 HansBug</a>
          </div>
        </div>
        <div class="hero-visual shell-card">
          <div class="hero-visual__art">
            <img src="/operator-echo.svg" alt="带有轻度角色感的终端风站点插画" />
          </div>
          <div class="hero-visual__label">
            <p class="eyebrow">终端视觉 / 站点形象</p>
            <strong>灰白工业感、警示橙、轻角色感，但仍然以阅读和可用性为先。</strong>
          </div>
          <div class="hero-dossier shell-card">
            <div class="profile-panel__head">
              <img class="profile-avatar" src={siteConfig.avatarPath} alt="HansBug 的 GitHub 头像" />
              <div class="profile-info">
                <p class="eyebrow">站点 / HansBug</p>
                <h2>技术写作新站</h2>
                <p>新文章、路线、标签和项目会先在这里稳定落地，逐步形成更长期的内容结构。</p>
              </div>
            </div>
            <div class="profile-badges">
              <span class="tag-chip is-red"><span>GitHub 头像</span></span>
              <span class="tag-chip is-orange"><span>新站建设中</span></span>
              <span class="tag-chip is-slate"><span>旧站已独立归档</span></span>
            </div>
            <div class="stat-grid profile-stats">
              <div>
                <strong>{posts.length}</strong>
                <span>新站文章</span>
              </div>
              <div>
                <strong>{routes.length}</strong>
                <span>路线页</span>
              </div>
              <div>
                <strong>{projects.length}</strong>
                <span>项目页</span>
              </div>
            </div>
            <p class="hero-dossier__note">
              新文章优先进入这里；旧站内容改走独立归档页。默认联系入口仍然是邮箱和 GitHub 反馈。
            </p>
          </div>
        </div>
      </div>
    </section>

    <section>
      <SectionHeading
        eyebrow="新内容入口"
        title="先把几个长期入口固定下来"
        description="即使新内容还在起步，首页也应该服务于以后要持续更新的文章、索引、路线和项目。"
      />
      <div class="grid-three">
        <article class="info-panel shell-card">
          <p class="eyebrow">博客</p>
          <h3>技术写作会先发布在这里</h3>
          <p>以后新的中文技术文章优先进入博客区，再通过标签和路线把它们组织起来。</p>
          <a class="inline-link" href="/blog/">查看博客入口</a>
        </article>
        <article class="info-panel shell-card">
          <p class="eyebrow">标签</p>
          <h3>按问题域进入，而不是只看时间线</h3>
          <p>标签页会承担长期检索和主题聚合，让读者能按问题而不是按月份找内容。</p>
          <a class="inline-link" href="/tags/">查看标签入口</a>
        </article>
        <article class="info-panel shell-card">
          <p class="eyebrow">路线 / 项目</p>
          <h3>把专题导航和长期实践分开整理</h3>
          <p>路线页负责阅读顺序和专题导引，项目页负责承接持续演化的工程实践。</p>
          <div class="hero-actions">
            <a class="inline-link" href="/routes/">路线页</a>
            <a class="inline-link" href="/projects/">项目页</a>
          </div>
        </article>
      </div>
    </section>

    <section class="grid-two">
      <article class="info-panel shell-card">
        <p class="eyebrow">旧站入口</p>
        <h2>历史内容放到独立归档页处理</h2>
        <p>
          旧博客园的主写作期覆盖 <strong>{oldBlogArchive.period}</strong>，共保留 <strong>{oldBlogArchive.totalPosts}</strong> 篇随笔、
          约 <strong>{oldBlogArchive.totalViewsText}</strong> 阅读。首页只保留一个入口，不再展开怀旧内容。
        </p>
        <div class="hero-actions">
          <a class="hero-action" href={siteConfig.oldBlogArchivePath}>查看旧站归档</a>
          <a class="hero-action" href={siteConfig.oldBlogUrl} target="_blank" rel="noreferrer">直达博客园</a>
        </div>
      </article>

      <article class="info-panel shell-card">
        <p class="eyebrow">更新策略</p>
        <h2>旧文不整批搬运，新文按新结构生长</h2>
        <p>
          旧站会保留历史链接、阅读量和发布时间作为参考；如果某个主题值得长期保留，更合适的方式是在新站里重写、重组，而不是直接复制。
        </p>
      </article>
    </section>

    <section class="cta-panel shell-card">
      <SectionHeading
        eyebrow="联系与反馈"
        title="如果你想交流、勘误或合作"
        description="邮件是最稳的联系入口；如果你是来找旧文，则先从旧站归档页进入会更合适。"
      />
      <div class="cta-actions">
        <a class="hero-action is-primary" href={`mailto:${siteConfig.email}`}>发送邮件</a>
        <a class="hero-action" href={siteConfig.oldBlogArchivePath}>打开旧站归档</a>
        <a class="hero-action" href={siteConfig.issueUrl} target="_blank" rel="noreferrer">提交反馈</a>
        <a class="hero-action" href={siteConfig.discussionsUrl} target="_blank" rel="noreferrer">公开讨论</a>
      </div>
    </section>
  </div>
</BaseLayout>
