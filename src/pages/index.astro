---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { siteConfig } from "../config/site";
import { getAllBlogPosts } from "../utils/content";

const posts = await getAllBlogPosts();
const recentPosts = posts.slice(0, 6);
---

<BaseLayout>
  <div class="page-grid home-page">
    <section class="home-intro shell-card">
      <div class="home-intro__copy">
        <p class="eyebrow">HansBug / 技术博客新站</p>
        <h1>新的技术文章，会从这里开始。</h1>
        <p class="home-intro__lead">
          这里专门承接新的中文技术写作。首页只展示新站本身，不再把说明、归档和历史内容混进来；后续更新会直接从这里出现。
        </p>
        <div class="hero-actions">
          <a class="hero-action is-primary" href="/blog/">进入博客</a>
          <a class="hero-action" href={siteConfig.rssUrl}>订阅 RSS</a>
          <a class="hero-action" href="/contact/">联系 HansBug</a>
        </div>
      </div>
    </section>

    <section class="home-feed shell-card">
      <SectionHeading
        eyebrow="最新文章"
        title={posts.length > 0 ? "最近更新" : "还没有新文章"}
        description={
          posts.length > 0
            ? "首页只展示新博客更新。更多文章可以直接进入博客页查看。"
            : "新站正文会从零开始整理。等第一批文章上线后，首页会直接展示它们。"
        }
      />

      {
        recentPosts.length > 0 ? (
          <div class="grid-two">
            {recentPosts.map((post) => <PostCard post={post} compact />)}
          </div>
        ) : (
          <section class="home-empty">
            <span class="home-empty__count">0 篇</span>
            <h2>第一批文章还在整理中</h2>
            <p>
              现在这里先留给未来的新写作。等第一批文章发布以后，首页会直接切成最新更新列表，不再额外塞别的说明模块。
            </p>
            <div class="hero-actions">
              <a class="hero-action is-primary" href="/blog/">打开博客页</a>
              <a class="hero-action" href={siteConfig.rssUrl}>查看 RSS</a>
            </div>
          </section>
        )
      }
    </section>
  </div>
</BaseLayout>
