---
import PostCard from "../components/PostCard.astro";
import ProjectCard from "../components/ProjectCard.astro";
import RouteCard from "../components/RouteCard.astro";
import SectionHeading from "../components/SectionHeading.astro";
import TagChip from "../components/TagChip.astro";
import { siteConfig } from "../config/site";
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  getAllBlogPosts,
  getAllProjects,
  getAllRoutes,
  getAllTags,
} from "../utils/content";

const [posts, routes, projects] = await Promise.all([
  getAllBlogPosts(),
  getAllRoutes(),
  getAllProjects(),
]);

const featuredPosts = posts.filter((post) => post.data.featured || post.data.pinned).slice(0, 3);
const latestPosts = (featuredPosts.length ? featuredPosts : posts).slice(0, 3);
const featuredRoutes = routes.slice(0, 3);
const featuredProjects = projects.slice(0, 3);
const tagOverview = getAllTags(posts).slice(0, 9);
---

<BaseLayout>
  <div class="page-grid">
    <section class="hero shell-card">
      <p class="eyebrow">HansBug / 个人技术博客</p>
      <div class="hero-grid">
        <div>
          <h1>把技术经验写成一套能持续生长的中文知识库。</h1>
          <p>
            这里重点记录工程实践、AI 应用、评测方法、工具链和长期维护经验。整体风格会保持克制、简洁，
            更像一块持续更新的工作台，而不是一次性展示页。
          </p>
          <div class="hero-actions">
            <a class="hero-action is-primary" href="/blog/">开始阅读</a>
            <a class="hero-action" href="/routes/">查看学习路线</a>
            <a class="hero-action" href="/contact/">联系 HansBug</a>
          </div>
        </div>
        <div class="stats-panel shell-card">
          <div class="stat-grid">
            <div>
              <strong>{posts.length}</strong>
              <span>篇博客文章</span>
            </div>
            <div>
              <strong>{routes.length}</strong>
              <span>条阅读路线</span>
            </div>
            <div>
              <strong>{projects.length}</strong>
              <span>个公开项目</span>
            </div>
          </div>
          <div>
            <p class="eyebrow">标签速览</p>
            <div class="tag-row">
              {tagOverview.map((item) => (
                <TagChip tag={item.tag} href={`/tags/${item.slug}/`} count={item.count} />
              ))}
            </div>
          </div>
          <div class="status-panel">
            <p class="eyebrow">Terminal Status</p>
            <ul class="status-list">
              <li>
                <strong>视觉方向</strong>
                <span>轻工业感、低饱和、轻度二次元、中文优先</span>
              </li>
              <li>
                <strong>内容组织</strong>
                <span>文章、路线、标签和项目互相引用，避免信息散落</span>
              </li>
              <li>
                <strong>默认沟通</strong>
                <span>邮件优先，公共讨论走 Issue 和 Discussions</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section>
      <SectionHeading
        eyebrow="快速开始"
        title="第一次来，建议从这里进入"
        description="我把内容拆成博客、路线和项目三层结构。博客看单篇，路线看体系，项目看长期实践。"
      />
      <div class="grid-three">
        <article class="info-panel shell-card">
          <p class="eyebrow">Route 01</p>
          <h3>从工程基础开始</h3>
          <p>如果你更关心仓库治理、Python 工具链、CI/CD 和交付质量，先看工程路线。</p>
          <a class="inline-link" href="/routes/engineering-foundation/">进入路线</a>
        </article>
        <article class="info-panel shell-card">
          <p class="eyebrow">Route 02</p>
          <h3>从 LLM 应用评测开始</h3>
          <p>如果你正做 AI 应用，建议先厘清评测对象、观测面和系统边界，再谈优化。</p>
          <a class="inline-link" href="/routes/llm-evaluation/">进入路线</a>
        </article>
        <article class="info-panel shell-card">
          <p class="eyebrow">Route 03</p>
          <h3>从写作与沉淀开始</h3>
          <p>如果你想搭自己的知识库或技术博客，这条路线会更贴近本站的设计思路。</p>
          <a class="inline-link" href="/routes/writing-workbench/">进入路线</a>
        </article>
      </div>
    </section>

    <section>
      <SectionHeading
        eyebrow="最新内容"
        title="近期更新的文章"
        description="文章按中文阅读体验组织，标签和路线系统会帮你继续往下读。"
      />
      <div class="grid-three">
        {latestPosts.map((post) => <PostCard post={post} />)}
      </div>
    </section>

    <section>
      <SectionHeading
        eyebrow="阅读路线"
        title="不是只看一篇，而是按主题成组阅读"
        description="每条路线都带有入口、关键问题和推荐顺序，适合作为长期学习或回顾用的索引。"
      />
      <div class="grid-three">
        {featuredRoutes.map((route) => <RouteCard route={route} />)}
      </div>
    </section>

    <section>
      <SectionHeading
        eyebrow="项目实践"
        title="把写作和项目相互校正"
        description="博客不是孤立的，它会和项目、实验记录和维护文档互相引用。"
      />
      <div class="grid-three">
        {featuredProjects.map((project) => <ProjectCard project={project} />)}
      </div>
    </section>

    <section class="cta-panel shell-card">
      <SectionHeading
        eyebrow="联系与反馈"
        title="如果你想交流、勘误或合作"
        description="邮件是最稳的联系入口；如果内容本身有问题，也欢迎通过 GitHub Issue 或 Discussions 留言。"
      />
      <div class="cta-actions">
        <a class="hero-action is-primary" href={`mailto:${siteConfig.email}`}>发送邮件</a>
        <a class="hero-action" href={siteConfig.issueUrl} target="_blank" rel="noreferrer">提交反馈</a>
        <a class="hero-action" href={siteConfig.discussionsUrl} target="_blank" rel="noreferrer">公开讨论</a>
      </div>
    </section>
  </div>
</BaseLayout>
