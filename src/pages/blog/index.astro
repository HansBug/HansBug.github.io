---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import { getAllBlogPosts } from "../../utils/content";

const posts = await getAllBlogPosts();
---

<BaseLayout title="博客">
  <section class="page-header shell-card">
    <p class="eyebrow">Blog</p>
    <h1>博客文章</h1>
    <p>
      这里收录所有中文技术文章。每篇文章都会挂上多个标签，并且尽量放到某条阅读路线里，方便从单点问题回到体系视角。
    </p>
    <div class="hero-actions">
      <a class="hero-action is-primary" href="/tags/">按标签浏览</a>
      <a class="hero-action" href="/archive/">按时间归档</a>
      <a class="hero-action" href="/search/">站内搜索</a>
    </div>
  </section>

  <section>
    <SectionHeading
      eyebrow="全部文章"
      title={`当前共 ${posts.length} 篇`}
      description="优先写那些真的能在未来复用的东西，而不是为了发一篇而发一篇。"
    />
    <div class="grid-two">
      {posts.map((post) => <PostCard post={post} />)}
    </div>
  </section>
</BaseLayout>
