---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import { siteConfig } from "../../config/site";
import { getAllBlogPosts, groupPostsByYear } from "../../utils/content";
import { formatDate } from "../../utils/date";

const posts = await getAllBlogPosts();
const archive = groupPostsByYear(posts);
---

<BaseLayout title="归档">
  <section class="page-header shell-card">
    <p class="eyebrow">归档</p>
    <h1>时间归档</h1>
    <p>如果你习惯按时间线回看博客演化，可以从这里进入。归档更适合观察关注点如何逐渐收敛。</p>
  </section>

  <div class="page-grid">
    {
      archive.length > 0 ? (
        archive.map((entry) => (
          <section class="archive-year shell-card">
            <SectionHeading
              eyebrow="年份"
              title={entry.year}
              description={`这一年共整理出 ${entry.posts.length} 篇文章。`}
            />
            <ul class="archive-list">
              {entry.posts.map((post) => (
                <li>
                  <a href={`/blog/${post.id}/`}>{post.data.title}</a>
                  <span>{formatDate(post.data.pubDate)}</span>
                </li>
              ))}
            </ul>
          </section>
        ))
      ) : (
        <section class="empty-state shell-card">
          <h2>新站归档还是空白</h2>
          <p>
            当前没有迁移旧文，所以时间线暂时没有条目。历史文章请先进入旧站归档页，那里会标出发布时间和阅读量。
          </p>
          <a class="hero-action" href={siteConfig.oldBlogArchivePath}>查看旧站归档</a>
        </section>
      )
    }
  </div>
</BaseLayout>
