---
import BaseLayout from "../../layouts/BaseLayout.astro";
import RouteCard from "../../components/RouteCard.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import { getAllRoutes } from "../../utils/content";

const routes = await getAllRoutes();
---

<BaseLayout title="路线">
  <section class="page-header shell-card">
    <p class="eyebrow">Routes</p>
    <h1>阅读路线</h1>
    <p>
      这里的路线不是教程目录，而是“如何进入一个问题域”的指引系统。你可以把它理解为带推荐顺序和关键问题的专题入口。
    </p>
  </section>

  <section>
    <SectionHeading
      eyebrow="阅读建议"
      title="按目标选择，而不是按热度选择"
      description="如果你想补基础，先看工程基础；如果你正在做 AI 应用，先看评测路线；如果你想搭自己的技术博客，直接看写作与沉淀路线。"
    />
    <div class="grid-three">
      {routes.map((route) => <RouteCard route={route} />)}
    </div>
  </section>
</BaseLayout>
